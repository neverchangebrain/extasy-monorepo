{
  "name": "extasy-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate": "bun --filter @extasy/db generate",
    "db:push": "bun --filter @extasy/db push",
    "db:studio": "bun --filter @extasy/db studio",
    "dev:assistant": "bun --watch apps/assistant-bot/src/index.ts",
    "format": "bunx @biomejs/biome format --write .",
    "check": "bunx @biomejs/biome check .",
    "check:fix": "bunx @biomejs/biome check --write .",
    "infra:down": "docker compose -f docker-compose.local.yml down",
    "infra:logs": "docker compose -f docker-compose.local.yml logs -f",
    "infra:up": "docker compose -f docker-compose.local.yml up -d"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  }
}
